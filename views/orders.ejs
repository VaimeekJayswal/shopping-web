<% var title = "Items"; %>

<h1>Your Orders</h1>

<% if (orders.length === 0) { %>
  <p class="muted">No orders yet.</p>
<% } else { %>
  <table>
    <tr>
      <th>Order ID</th>
      <th>Total</th>
      <th>Date</th>
    </tr>
    <% orders.forEach(o => { %>
      <tr>
        <td>#<%= o.id %></td>
        <td>₹ <%= o.total %></td>
        <td><%= o.created_at %></td>
      </tr>
    <% }) %>
  </table>
<% } %>
